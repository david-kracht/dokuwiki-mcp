MCP_TRANSPORT="streamable-http"
MCP_ALLOW_ALL_HOSTS=true

HOST=0.0.0.0

# Deine DokuWiki URL
DOKUWIKI_URL=http://localhost:8080

# DokuWiki URL-Rewrite Modus (userewrite):
# 0 = doku.php?id=seite
# 1 = /seite (Webserver-Rewrite)
# 2 = doku.php/seite
DOKUWIKI_URL_REWRITE=0

# Dein Read-Only Fallback Token
DOKUWIKI_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJkb2t1d2lraSIsInN1YiI6Im1jcC1yZWFkIiwiaWF0IjoxNzc1OTQzMTk5fQ==.rBdJZeCuNIUQrVjHv7p14aogj0aSWDwWjftweYIiRZY=

# Optional: User/Passwort (werden ignoriert, solange ein Token da ist)
DOKUWIKI_USER=mcp-read
DOKUWIKI_PASSWORD=mcp