# DokuWiki MCP Environment Configuration Template
# Copy this file to '.env' and fill in your confidential keys.

# Google Gemini API Key (required for Stufe 2 Live-LLM Benchmark Evaluation & Optimization)
GEMINI_API_KEY=

# DokuWiki RPC Client Settings
DOKUWIKI_URL=http://localhost:8080/lib/exe/xmlrpc.php
DOKUWIKI_USER=admin
DOKUWIKI_PASSWORD=admin

# MCP Telemetry & Benchmark Configuration
MCP_ENABLE_TELEMETRY=true
MCP_LOG_LEVEL=INFO
